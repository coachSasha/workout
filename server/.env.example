PORT=3001
NODE_ENV=development

SPREADSHEET_ID=your_spreadsheet_id_here

# Вариант A (рекомендуется для Render): весь JSON ключа одной строкой
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}

# Вариант B: отдельно email и private_key из JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

TRAINER_PASSWORD=change_me_strong_password
JWT_SECRET=change_me_random_string_at_least_32_chars

CLIENT_URL=http://localhost:5173

# Создать листы Clients/Sessions с заголовками при старте, если отсутствуют
INIT_SHEETS=true

# Кэш чтения Sheets (секунды)
CACHE_TTL_SECONDS=45

DEFAULT_TIMEZONE=Europe/Moscow
SLOT_DURATION_MINUTES=60
